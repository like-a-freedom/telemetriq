{
  "name": "telemetriq",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "vitest run --coverage",
    "test:performance": "bun vitest run src/__tests__/videoProcessingPerformance.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint --max-warnings=0 \"src/**/*.{js,ts,vue}\"",
    "lint:fix": "eslint --max-warnings=0 \"src/**/*.{js,ts,vue}\" --fix",
    "fetch-ffmpeg-core": "mkdir -p public/vendor/ffmpeg && curl -fL https://cdn.jsdelivr.net/npm/@ffmpeg/core@latest/dist/esm/ffmpeg-core.js -o public/vendor/ffmpeg/ffmpeg-core.js && curl -fL https://cdn.jsdelivr.net/npm/@ffmpeg/core@latest/dist/esm/ffmpeg-core.wasm -o public/vendor/ffmpeg/ffmpeg-core.wasm",
    "benchmark:webgpu": "vitest run src/__tests__/webgpu-benchmark.test.ts",
    "benchmark:performance": "node scripts/benchmark.js"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@unhead/vue": "^3.1.0",
    "@vueuse/core": "^14.3.0",
    "@webgpu/types": "^0.1.69",
    "agent-browser": "^0.26.0",
    "mediabunny": "^1.43.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/dom-webcodecs": "^0.1.18",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-plugin-vue": "^10.9.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "terser": "^5.46.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.8"
  },
  "trustedDependencies": [
    "agent-browser",
    "edgedriver"
  ]
}