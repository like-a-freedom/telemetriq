{
  "name": "telemetriq",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "bun vitest run",
    "test:watch": "bun vitest",
    "test:coverage": "vitest run --coverage",
    "test:performance": "bun vitest run src/__tests__/videoProcessingPerformance.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint --max-warnings=0 \"src/**/*.{js,ts,vue}\"",
    "lint:fix": "eslint --max-warnings=0 \"src/**/*.{js,ts,vue}\" --fix",
    "fetch-ffmpeg-core": "mkdir -p public/vendor/ffmpeg && curl -fL https://cdn.jsdelivr.net/npm/@ffmpeg/core@latest/dist/esm/ffmpeg-core.js -o public/vendor/ffmpeg/ffmpeg-core.js && curl -fL https://cdn.jsdelivr.net/npm/@ffmpeg/core@latest/dist/esm/ffmpeg-core.wasm -o public/vendor/ffmpeg/ffmpeg-core.wasm"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@unhead/vue": "^3.1.6",
    "@vueuse/core": "^14.3.0",
    "@webgpu/types": "^0.1.71",
    "agent-browser": "^0.31.0",
    "mediabunny": "^1.49.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/dom-webcodecs": "^0.1.18",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "trustedDependencies": [
    "agent-browser",
    "edgedriver"
  ]
}